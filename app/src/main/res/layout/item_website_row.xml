<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/card_background"
    android:layout_marginBottom="8dp">
    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:id="@+id/tvDomain"
        android:textSize="14sp" android:textColor="@color/text_primary"
        android:drawablePadding="8dp"/>
    <TextView android:id="@+id/tvRemoveSite"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🗑️" android:textSize="18sp" android:padding="4dp"/>
</LinearLayout>
