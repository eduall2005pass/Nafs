<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
   >

    <!-- Overlay: block screen দেখাতে -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Boot auto-start -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- VPN / Internet -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Biometric -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <!-- Recent tasks থেকে remove করতে -->
    <uses-permission android:name="android.permission.REORDER_TASKS" />

    <!-- AlarmManager exact alarm — bg restart এর জন্য (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Samsung A35: background activity launch (OneUI 6) -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:usesCleartextTraffic="false"
        android:allowBackup="false"
        android:debuggable="false"
        android:hardwareAccelerated="true"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.NafsShield"
        android:supportsRtl="true"
        android:hardwareAccelerated="true">

        <!-- ── SplashActivity ── -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:theme="@style/Theme.NafsShield"
            android:noHistory="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.language.LanguageActivity"
            android:exported="false"
            android:theme="@style/Theme.NafsShield" />

        <!-- ── MainActivity ── -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:excludeFromRecents="false"
            android:launchMode="standard"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- PIN Screen -->
        <activity
            android:name=".ui.pin.PinActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:showOnLockScreen="true"
            android:launchMode="standard" />

        <!-- ── MasterService ── -->
        <service
            android:name=".service.MasterService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="guardService" />
        </service>

        <!-- ── AccessibilityService ── -->
        <service
            android:name=".service.NafsAccessibilityService"
            android:isAccessibilityTool="true"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- ── VPN Service ── -->
        <service
            android:name=".service.NafsVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:stopWithTask="false">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpnService" />
        </service>

        <!-- ── Device Admin ── -->
        <receiver
            android:name=".admin.NafsDeviceAdmin"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- ── Share Activity — অন্য app থেকে keyword/URL add ── -->
        <activity
            android:name=".ui.share.ShareActivity"
            android:exported="true"
            android:theme="@style/Theme.NafsShield"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- ── Boot Receiver ── -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.sec.android.app.launcher.QUICKBOOT_POWERON" />
                <action android:name="com.nafsshield.RESTART_SERVICE" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
